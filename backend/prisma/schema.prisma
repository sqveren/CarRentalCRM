generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum CarStatus {
  available
  rented
  maintenance
  cleaning
  damaged
}

model Role {
  id        Int        @id @default(autoincrement())
  name      String     @unique @db.VarChar(50)
  employees Employee[]

  @@map("roles")
}

model Employee {
  id           Int      @id @default(autoincrement())
  firstName    String   @map("first_name") @db.VarChar(50)
  lastName     String   @map("last_name") @db.VarChar(50)
  roleId       Int      @map("role_id")
  login        String   @unique @db.VarChar(50)
  passwordHash String   @map("password_hash") @db.VarChar(255)
  role         Role     @relation(fields: [roleId], references: [id])
  rentals      Rental[]

  @@map("employees")
}

model Client {
  id             Int      @id @default(autoincrement())
  firstName      String   @map("first_name") @db.VarChar(50)
  lastName       String   @map("last_name") @db.VarChar(50)
  phone          String?  @db.VarChar(20)
  email          String?  @db.VarChar(100)
  documentNumber String?  @unique @map("document_number") @db.VarChar(50)
  rentals        Rental[]

  @@map("clients")
}

model CarCategory {
  id          Int    @id @default(autoincrement())
  name        String @db.VarChar(50)
  pricePerDay Decimal @map("price_per_day") @db.Decimal(10, 2)
  cars        Car[]

  @@map("car_categories")
}

model Car {
  id              Int          @id @default(autoincrement())
  brand           String       @db.VarChar(50)
  model           String       @db.VarChar(50)
  manufactureYear Int?         @map("manufacture_year")
  mileage         Int?         @default(0)
  status          CarStatus    @default(available)
  categoryId      Int          @map("category_id")
  category        CarCategory  @relation(fields: [categoryId], references: [id])
  rentals         Rental[]

  @@map("cars")
}

model Rental {
  id             Int             @id @default(autoincrement())
  clientId       Int             @map("client_id")
  carId          Int             @map("car_id")
  employeeId     Int             @map("employee_id")
  startDate      DateTime        @map("start_date")
  endDate        DateTime        @map("end_date")
  startMileage   Int?            @map("start_mileage")
  endMileage     Int?            @map("end_mileage")
  totalPrice     Decimal?        @map("total_price") @db.Decimal(10, 2)
  status         String          @default("active") @db.VarChar(20)
  client         Client          @relation(fields: [clientId], references: [id], onDelete: Cascade)
  car            Car             @relation(fields: [carId], references: [id])
  employee       Employee        @relation(fields: [employeeId], references: [id])
  payments       Payment[]
  fines          Fine[]
  rentalServices RentalService[]

  @@map("rentals")
}

model Payment {
  id          Int      @id @default(autoincrement())
  rentalId    Int      @map("rental_id")
  amount      Decimal  @db.Decimal(10, 2)
  paymentDate DateTime @default(now()) @map("payment_date")
  rental      Rental   @relation(fields: [rentalId], references: [id], onDelete: Cascade)

  @@map("payments")
}

model Fine {
  id          Int      @id @default(autoincrement())
  rentalId    Int      @map("rental_id")
  description String?
  amount      Decimal  @db.Decimal(10, 2)
  rental      Rental   @relation(fields: [rentalId], references: [id], onDelete: Cascade)

  @@map("fines")
}

model Service {
  id             Int             @id @default(autoincrement())
  name           String          @db.VarChar(100)
  price          Decimal         @db.Decimal(10, 2)
  rentalServices RentalService[]

  @@map("services")
}

model RentalService {
  rentalId  Int     @map("rental_id")
  serviceId Int     @map("service_id")
  rental    Rental  @relation(fields: [rentalId], references: [id], onDelete: Cascade)
  service   Service @relation(fields: [serviceId], references: [id])

  @@id([rentalId, serviceId])
  @@map("rental_services")
}
